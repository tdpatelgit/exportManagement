# Copy this file to `.env` and fill in real values before deploying.
# .env is never committed to source control (see .gitignore).

# Flask session signing key - use a long random string in production.
# You can generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# Where the SQLite database file should live. Leave unset to use the
# default (instance/crm.db inside the project folder).
# DATABASE_PATH=/absolute/path/to/crm.db

# Local dev server settings (used by run.py)
HOST=127.0.0.1
PORT=5000
DEBUG=true
